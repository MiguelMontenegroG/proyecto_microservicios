pipeline {
    agent any

    environment {
        SERVICE_NAME = "python-healthcheck-service"
        IMAGE_NAME   = "python-healthcheck-service"
        IMAGE_TAG    = "${env.BUILD_NUMBER}"
        REGISTRY     = "localhost:5000"
        SONAR_HOST   = "http://sonarqube:9000"
        CODE_DIR     = "/code/python-healthcheck-service"
        DOCKER_CODE  = "/run/desktop/mnt/host/c/Users/ANGEL/Desktop/Universidad/202601/Microservicios/proyecto/python-healthcheck-service"
        DOCKER_PROJ  = "/run/desktop/mnt/host/c/Users/ANGEL/Desktop/Universidad/202601/Microservicios/proyecto"
    }

    options {
        timeout(time: 20, unit: 'MINUTES')
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {

        stage('Checkout') {
            steps {
                echo "Verificando codigo fuente..."
                sh "ls -la ${CODE_DIR}/"
            }
        }

        stage('Build') {
            steps {
                sh """
                    docker run --rm \
                        -v ${DOCKER_PROJ}:${DOCKER_PROJ} \
                        -v /var/run/docker.sock:/var/run/docker.sock \
                        --network host \
                        python:3.11-slim \
                        sh -c "cd ${DOCKER_CODE} && pip install -r requirements.txt --quiet"
                """
                echo "Dependencias instaladas correctamente"
            }
        }

        stage('Test') {
            steps {
                sh """
                    docker run --rm \
                        -v ${DOCKER_PROJ}:${DOCKER_PROJ} \
                        -v /var/run/docker.sock:/var/run/docker.sock \
                        --network host \
                        python:3.11-slim \
                        sh -c "cd ${DOCKER_CODE} && pip install pytest pytest-cov --quiet && \
                            pytest tests/ \
                                --cov=. \
                                --cov-report=xml:coverage.xml \
                                --cov-report=term-missing \
                                --junitxml=test-results.xml \
                                -v || true"
                """
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: "${CODE_DIR}/test-results.xml"
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                    sh """
                        docker run --rm \
                            -v ${DOCKER_PROJ}:${DOCKER_PROJ} \
                            -v /var/run/docker.sock:/var/run/docker.sock \
                            --network host \
                            -e SONAR_TOKEN=${SONAR_TOKEN} \
                            python:3.11-slim \
                            sh -c "
                                cd ${DOCKER_CODE}
                                apt-get update && apt-get install -y curl unzip && rm -rf /var/lib/apt/lists/*
                                curl -sL 'https://binaries.sonarsource.com/Distribution/sonar-scanner-cli/sonar-scanner-cli-5.0.1.3006-linux.zip' -o /tmp/sonar-scanner.zip
                                unzip -q /tmp/sonar-scanner.zip -d /opt/
                                /opt/sonar-scanner-5.0.1.3006-linux/bin/sonar-scanner \
                                    -Dsonar.projectKey=${SERVICE_NAME} \
                                    -Dsonar.projectName=${SERVICE_NAME} \
                                    -Dsonar.sources=. \
                                    -Dsonar.exclusions=tests/**,**/__pycache__/**,*.xml \
                                    -Dsonar.python.coverage.reportPaths=coverage.xml \
                                    -Dsonar.host.url=${SONAR_HOST} \
                                    -Dsonar.token=\${SONAR_TOKEN}
                            "
                    """
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Package') {
            steps {
                script {
                    sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} -t ${IMAGE_NAME}:latest ${CODE_DIR}"
                    sh "docker tag ${IMAGE_NAME}:${IMAGE_TAG} ${REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}"
                    sh "docker push ${REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG} || echo 'Push al registry fallo (continua)'"
                    echo "Imagen Python construida: ${IMAGE_NAME}:${IMAGE_TAG}"
                }
            }
        }

    }

    post {
        success {
            echo "Pipeline de ${SERVICE_NAME} completado (Build #${BUILD_NUMBER})"
        }
        failure {
            echo "Pipeline de ${SERVICE_NAME} fallo"
        }
    }
}
